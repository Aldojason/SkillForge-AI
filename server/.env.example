# ==========================================
# SkillForge AI — Server Environment Variables
# ==========================================
# Copy this file to .env and fill in real values.

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (Neon / any PostgreSQL) ---
# Connection string for your Postgres instance.
# Example for Neon: postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/skillforge?schema=public"

# --- JWT Auth ---
# Generate strong random secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string

# --- Razorpay (payment gateway) ---
# Get your keys from: https://dashboard.razorpay.com → Account & Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxx

# --- Cloudinary (resume / avatar file uploads) ---
# Get your credentials from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email / SMTP (password reset, verification) ---
# Example using Resend: https://resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
EMAIL_FROM="SkillForge AI <no-reply@skillforge.ai>"

# --- AI (resume review, mock interview, study coach) ---
# Get your key from: https://aistudio.google.com → Get API key
# Key should start with "AIza..."
GEMINI_API_KEY=
